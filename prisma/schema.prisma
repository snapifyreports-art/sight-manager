generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum UserRole {
  // (May 2026 audit #201) SUPER_ADMIN — operator role that can access
  // every site without explicit UserSite rows, manage users + roles
  // app-wide, and view tenant-level audit. Reserved for the
  // platform-operator's own staff (not Keith's team). Above CEO in
  // privilege but should never be assigned via the in-app UI — it's
  // set by direct DB update during onboarding.
  SUPER_ADMIN
  CEO
  DIRECTOR
  SITE_MANAGER
  CONTRACT_MANAGER
  CONTRACTOR
}

enum SiteStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum JobStatus {
  NOT_STARTED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
}

enum OrderStatus {
  PENDING
  ORDERED
  CONFIRMED
  DELIVERED
  CANCELLED
}

enum ContactType {
  SUPPLIER
  CONTRACTOR
}

enum NotificationType {
  JOBS_STARTING_TODAY
  JOBS_OVERDUE
  MATERIALS_OVERDUE
  DELIVERIES_DUE_TODAY
  JOBS_READY_FOR_SIGNOFF
  NEW_NOTES_PHOTOS
  ORDERS_TO_SEND
  NEXT_STAGE_READY
  LATE_STARTS
  WEATHER_ALERT
  // (May 2026 audit follow-up to #152) Per-site event notification
  // types. Issued by sendPushToSiteAudience so a manager can mute
  // specific event classes via their preference grid rather than
  // muting NEW_NOTES_PHOTOS wholesale.
  SNAG_RAISED
  DELIVERY_CONFIRMED
  JOB_MILESTONE
}

enum SnagPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SnagStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum WeatherImpactType {
  RAIN
  TEMPERATURE
}

enum EventType {
  JOB_STARTED
  JOB_COMPLETED
  JOB_STOPPED
  JOB_EDITED
  JOB_SIGNED_OFF
  ORDER_PLACED
  ORDER_DELIVERED
  ORDER_CANCELLED
  DELIVERY_CONFIRMED
  PHOTO_UPLOADED
  SCHEDULE_CASCADED
  SITE_CREATED
  SITE_UPDATED
  PLOT_CREATED
  PLOT_UPDATED
  SNAG_CREATED
  SNAG_RESOLVED
  LATENESS_OPENED
  LATENESS_RESOLVED
  USER_ACTION
  NOTIFICATION
  SYSTEM
}

/// (#191) Lateness — a first-class record of every time something
/// on this site fell behind. The cron creates rows; managers
/// optionally tag a reason + attribution; reports aggregate.
enum LatenessKind {
  JOB_END_OVERDUE        // job past planned endDate, not COMPLETED
  JOB_START_OVERDUE      // job NOT_STARTED past startDate
  ORDER_DELIVERY_OVERDUE // order past expectedDeliveryDate, not DELIVERED
  ORDER_SEND_OVERDUE     // order past dateOfOrder, still PENDING
}

enum LatenessReason {
  WEATHER_RAIN
  WEATHER_TEMPERATURE
  WEATHER_WIND
  MATERIAL_LATE
  MATERIAL_WRONG
  MATERIAL_SHORT
  LABOUR_NO_SHOW
  LABOUR_SHORT
  DESIGN_CHANGE
  SPEC_CLARIFICATION
  PREDECESSOR_LATE
  ACCESS_BLOCKED
  INSPECTION_FAILED
  OTHER
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(CONTRACTOR)
  jobTitle  String?
  company   String?
  phone     String?
  avatar    String?
  /// (May 2026 audit S-P0) Soft-delete pattern. Pre-fix User FKs
  /// defaulted to Restrict — once a user had any historical activity
  /// (signed off a job, raised a snag, etc.) HR could never offboard
  /// them. Now: admin clicks "Archive user" → `archivedAt` stamped →
  /// user can't log in (auth check), filtered out of every picker,
  /// but all historical attribution survives. Restoring just clears
  /// the field.
  archivedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sites                   Site[]
  assignedSites           Site[]                   @relation("AssignedSites")
  assignedJobs            Job[]                    @relation("AssignedJobs")
  signedOffJobs           Job[]                    @relation("SignedOffJobs")
  events                  EventLog[]
  jobActions              JobAction[]
  uploadedPhotos          JobPhoto[]
  pushSubscriptions       PushSubscription[]
  notificationPreferences NotificationPreference[]
  permissions             UserPermission[]
  siteAccess              UserSite[]
  snagsAssigned           Snag[]                   @relation("SnagAssigned")
  snagsRaised             Snag[]                   @relation("SnagRaised")
  snagsResolved           Snag[]                   @relation("SnagResolved")
  uploadedDocuments       SiteDocument[]           @relation("UploadedDocuments")
  checkedHandovers        HandoverChecklist[]      @relation("CheckedHandoverItems")
  plotJournalEntries      PlotJournalEntry[]       @relation("PlotJournalAuthor")
  watchedSites            WatchedSite[]
  recordedLatenessEvents  LatenessEvent[]          @relation("LatenessEventRecorder")
}

model Site {
  id           String     @id @default(cuid())
  name         String
  description  String?
  location     String?
  address      String?
  postcode     String?
  status       SiteStatus @default(ACTIVE)
  createdById  String
  assignedToId String?
  // Set when site status flips to COMPLETED — used as the canonical
  // "story end date" for the Site Story tab and the Handover ZIP. Not
  // updatable directly; set via a status-change side effect so we
  // capture the actual moment of closure rather than mutation time.
  completedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  createdBy        User                 @relation(fields: [createdById], references: [id])
  assignedTo       User?                @relation("AssignedSites", fields: [assignedToId], references: [id])
  plots            Plot[]
  events           EventLog[]
  rainedOffDays    RainedOffDay[]
  documents        SiteDocument[]
  userAccess       UserSite[]
  oneOffOrders     MaterialOrder[] // back-relation for MaterialOrder.siteId (one-off orders)
  watchers         WatchedSite[]
  complianceItems  SiteComplianceItem[]
  toolboxTalks     ToolboxTalk[]
  nonConformances  NCR[]
  latenessEvents   LatenessEvent[]

  @@index([status]) // (audit P-*) `status: { not: COMPLETED }` is the
  //                   most common Site filter in cron + dashboard queries
}

model RainedOffDay {
  id        String            @id @default(cuid())
  siteId    String
  date      DateTime
  type      WeatherImpactType @default(RAIN)
  note      String?
  createdAt DateTime          @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, date, type])
  // (May 2026 audit S-P1) Cross-site "all rained-off days in range"
  // queries (weather cron + analytics) couldn't use the composite
  // unique index since they don't filter by siteId. Single-column
  // date index keeps the scan tight.
  @@index([date])
}

model Plot {
  id                             String    @id @default(cuid())
  name                           String
  description                    String?
  siteId                         String
  plotNumber                     String?
  reservationType                String?
  houseType                      String?
  reservationDate                DateTime?
  exchangeDate                   DateTime?
  legalDate                      DateTime?
  approvalG                      Boolean   @default(false)
  approvalE                      Boolean   @default(false)
  approvalW                      Boolean   @default(false)
  approvalKCO                    Boolean   @default(false)
  buildCompletePercent           Float     @default(0)
  awaitingRestart                Boolean   @default(false)
  awaitingContractorConfirmation Boolean   @default(false)
  // (May 2026 Keith request) House value — both figures, per plot.
  // `buildBudget` = the target build cost; `salePrice` = the GDV the
  // finished home sells for. Snapshotted from the source variant (or
  // base template) at apply time, then editable per-plot. The Budget
  // report compares actual spend against buildBudget, and salePrice
  // against both for the margin picture.
  buildBudget                    Float?
  salePrice                      Float?
  // Informational link to the PlotTemplate this plot was created from.
  // No auto-sync: plots snapshot the template at apply time. Nullable
  // so pre-existing and manually-created plots are unaffected.
  sourceTemplateId               String?
  // Optional pointer to the variant chosen at apply time. Captured for
  // reporting / drift detection; not used at runtime by the cascade.
  sourceVariantId                String?
  // Customer share token — unguessable random string used in the public
  // /share/<token> URL. Generated lazily the first time admin clicks
  // "Get share link" on the Customer view tab. Rotating regenerates;
  // disabling clears `shareEnabled` (token retained so re-enable
  // restores the same link).
  shareToken                     String?   @unique
  shareEnabled                   Boolean   @default(true)
  createdAt                      DateTime  @default(now())
  updatedAt                      DateTime  @updatedAt

  site              Site                @relation(fields: [siteId], references: [id], onDelete: Cascade)
  sourceTemplate    PlotTemplate?       @relation("PlotSourceTemplate", fields: [sourceTemplateId], references: [id], onDelete: SetNull)
  sourceVariant     TemplateVariant?    @relation("PlotVariant", fields: [sourceVariantId], references: [id], onDelete: SetNull)
  jobs              Job[]
  events            EventLog[]
  snags             Snag[]
  documents         SiteDocument[]
  handoverChecklist     HandoverChecklist[]
  materials             PlotMaterial[]
  oneOffOrders          MaterialOrder[] // back-relation for MaterialOrder.plotId (plot-level one-off)
  journalEntries        PlotJournalEntry[]
  ncrs                  NCR[]
  preStartChecks        PreStartCheck[]
  variations            Variation[]
  defectReports         DefectReport[]
  customerSubscriptions CustomerPushSubscription[]
  drawSchedule          PlotDrawSchedule[]
  voiceNotes            VoiceNote[]
  photoAnnotations      PhotoAnnotation[]
  latenessEvents        LatenessEvent[]

  @@unique([siteId, plotNumber])
  @@index([siteId]) // hot path: every site page loads plots
}

// Customer-facing journal — short story-style updates the admin posts
// against a plot, surfaced on the public /share/<token> page intermixed
// chronologically with shared photos. Plain text; no dates rendered to
// the customer (they see "1 week ago" / sequence only). Soft-deletable
// by clearing the row entirely (no soft delete to keep the public read
// path narrow).
model PlotJournalEntry {
  id          String   @id @default(cuid())
  plotId      String
  body        String
  createdById String?
  createdAt   DateTime @default(now())

  plot      Plot  @relation(fields: [plotId], references: [id], onDelete: Cascade)
  createdBy User? @relation("PlotJournalAuthor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([plotId, createdAt])
}

model Job {
  id                  String    @id @default(cuid())
  name                String
  description         String?
  plotId              String
  location            String?
  address             String?
  startDate           DateTime?
  endDate             DateTime?
  // Original planned dates — NOT NULL since May 2026 audit. Every job
  // creation site must stamp these alongside startDate/endDate so
  // reports (cash-flow, daily-brief, delay-report) never fall back
  // to current dates and silently mix "original" with "actual" data.
  originalStartDate   DateTime
  originalEndDate     DateTime
  status              JobStatus @default(NOT_STARTED)
  assignedToId        String?
  stageCode           String?
  actualStartDate     DateTime?
  actualEndDate       DateTime?
  signedOffById       String?
  signedOffAt         DateTime?
  signOffNotes        String?
  sortOrder           Int       @default(0)
  weatherAffected     Boolean   @default(false)
  weatherAffectedType String? // "RAIN" | "TEMPERATURE" | "BOTH"
  parentId            String?
  parentStage         String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  plot        Plot            @relation(fields: [plotId], references: [id], onDelete: Cascade)
  assignedTo  User?           @relation("AssignedJobs", fields: [assignedToId], references: [id])
  signedOffBy User?           @relation("SignedOffJobs", fields: [signedOffById], references: [id])
  parent      Job?            @relation("SubJobs", fields: [parentId], references: [id], onDelete: SetNull)
  children    Job[]           @relation("SubJobs")
  orders      MaterialOrder[]
  events      EventLog[]
  actions     JobAction[]
  contractors JobContractor[]
  photos      JobPhoto[]
  documents   SiteDocument[]
  snags       Snag[]
  ncrs        NCR[]
  latenessEvents LatenessEvent[]

  @@index([plotId])       // hot: programme, daily-brief, reports join on plot
  @@index([status])       // hot: "NOT_STARTED where startDate < today" etc.
  @@index([parentId])     // hot: children / rollup checks
  // (May 2026 audit P-*) Date-range filters appear on every Daily Brief
  // / Programme / lateness-cron query; pre-fix these were sequential
  // scans on big-site data sets.
  @@index([startDate])
  @@index([endDate])
  @@index([actualEndDate])
  @@index([plotId, status]) // composite for the hottest filter combo
}

/// (May 2026 audit B-P1-28) JobAction is APPEND-ONLY. Every
/// start/stop/complete/note/signoff stamps a row used by Delay Report
/// + Site Story aggregations. UPDATE and DELETE are blocked by a
/// Postgres trigger installed via scripts/apply-immutability-triggers.ts
/// — alongside EventLog. Do NOT use prisma.jobAction.update or
/// prisma.jobAction.deleteMany in application code; the trigger will
/// raise an exception. Genuine row fixes (GDPR, typo) require dropping
/// the trigger temporarily — see the script header.
model JobAction {
  id        String   @id @default(cuid())
  jobId     String
  userId    String
  action    String
  notes     String?
  createdAt DateTime @default(now())

  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([jobId])        // hot: weekly report / analytics aggregates
}

model JobContractor {
  id        String   @id @default(cuid())
  jobId     String
  contactId String
  createdAt DateTime @default(now())

  job     Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([jobId, contactId])
  @@index([contactId])    // hot: contractor comms group-by contactId
}

model JobPhoto {
  id           String   @id @default(cuid())
  jobId        String
  url          String
  fileName     String?
  caption      String?
  tag          String? // "before", "after", "progress"
  uploadedById String?
  // Per-photo opt-in for the customer-facing /share/<token> page. Off
  // by default — admin must explicitly tick a photo to share. Default
  // false is the contractually safe choice: a wonky-brick photo never
  // leaks to a buyer because someone forgot to untick it.
  sharedWithCustomer Boolean @default(false)
  createdAt    DateTime @default(now())

  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  uploadedBy  User?             @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  annotations PhotoAnnotation[]

  @@index([jobId, sharedWithCustomer])
  @@index([createdAt]) // (audit P-*) photo grids order by createdAt DESC
}

model Supplier {
  id            String   @id @default(cuid())
  name          String
  contactName   String?
  contactEmail  String?
  contactNumber String?
  type          String?
  emailTemplate String?
  accountNumber String?
  /// (May 2026 audit S-P0) Soft-delete. Suppliers with historical
  /// orders stay queryable; archived ones drop out of the pickers.
  archivedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders         MaterialOrder[]
  templateOrders TemplateOrder[]
  materials      SupplierMaterial[]
  latenessEvents LatenessEvent[]
}

model SupplierMaterial {
  id         String   @id @default(cuid())
  supplierId String
  name       String
  unit       String   @default("each")
  unitCost   Float    @default(0)
  category   String?
  sku        String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([supplierId, name])
}

model MaterialOrder {
  id                   String      @id @default(cuid())
  supplierId           String
  // jobId is optional to allow one-off orders at site or plot level (not tied to a template job).
  // Either jobId OR (siteId set, with optional plotId) must be present — enforced at API level.
  jobId                String?
  siteId               String?
  plotId               String?
  contactId            String?
  orderDetails         String?
  dateOfOrder          DateTime    @default(now())
  orderType            String?
  automated            Boolean     @default(false)
  // oneOff orders are site- or plot-level orders not tied to a specific template job
  oneOff               Boolean     @default(false)
  // (#169) Split-out flag — true when the manager has extracted this
  // order from a visual group so it can be re-dated independently
  // (e.g. when one plot is pulled forward). UI groups orders by
  // supplier + job.name + (isSplit ? id : "default") so split orders
  // fall into their own row instead of bundling with siblings.
  isSplit              Boolean     @default(false)
  status               OrderStatus @default(PENDING)
  expectedDeliveryDate DateTime?
  deliveredDate        DateTime?
  leadTimeDays         Int?
  itemsDescription     String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  supplier   Supplier    @relation(fields: [supplierId], references: [id])
  // (May 2026 audit S-P0) Jobs / Plots / Sites are NEVER deleted in
  // practice (Keith confirmed) — but if anyone ever does, Cascade
  // would silently wipe DELIVERED orders + lateness events + audit
  // trail. SetNull preserves the delivery + invoice history; the
  // orphan order shows "(deleted job)" in the UI but the financials
  // stay intact.
  job        Job?        @relation(fields: [jobId], references: [id], onDelete: SetNull)
  site       Site?       @relation(fields: [siteId], references: [id], onDelete: SetNull)
  plot       Plot?       @relation(fields: [plotId], references: [id], onDelete: SetNull)
  contact    Contact?    @relation(fields: [contactId], references: [id], onDelete: SetNull)
  orderItems OrderItem[]
  latenessEvents LatenessEvent[]

  @@index([jobId])                 // hot: job → orders on every programme / daily-brief / panel
  @@index([status])                // hot: Tasks filters status=PENDING globally
  @@index([expectedDeliveryDate])  // hot: deliveries-today / upcoming-deliveries range queries
  @@index([supplierId])            // hot: Supplier Performance report groups orders by supplier
  // (May 2026 audit P-*) Cash flow / supplier performance / late-cron
  // queries filter on these regularly.
  @@index([dateOfOrder])
  @@index([deliveredDate])
  @@index([contactId])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  name      String
  quantity  Float    @default(1)
  unit      String   @default("units")
  unitCost  Float    @default(0)
  totalCost Float    @default(0)
  createdAt DateTime @default(now())

  order MaterialOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])  // hot: every order detail fetches its items
}

model Contact {
  id        String      @id @default(cuid())
  name      String
  email     String?
  phone     String?
  type      ContactType
  company   String?
  notes     String?
  /// (May 2026 audit S-P0) Soft-delete pattern. Same as User —
  /// `archivedAt` non-null means the contact is offboarded.
  /// Filtered out of pickers + scorecard rollups but historical
  /// references (jobs they did, snags they raised) survive.
  archivedAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  orders         MaterialOrder[]
  jobContractors JobContractor[]
  templateJobs   TemplateJob[]
  snags          Snag[]
  documents      SiteDocument[]
  ncrs           NCR[]
  attributedLatenessEvents LatenessEvent[]
}

// ---------- Plot Templates ----------

model PlotTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  typeLabel   String?
  // Draft templates are hidden from the apply-to-plot picker so a half-built
  // template can't accidentally be applied to a live site. Defaults false so
  // every existing template stays "live" on schema upgrade; the UI flips
  // newly-created templates to draft until the user marks them ready.
  isDraft     Boolean  @default(false)
  /// (May 2026 audit S-P0) Soft-archive. Lets the team retire an old
  /// template (e.g. discontinued house type) without losing the link
  /// from historical Plots that were applied from it.
  archivedAt  DateTime?
  // (May 2026 Keith request) House value — base/default figures for the
  // template. `buildBudget` = target build cost, `salePrice` = GDV.
  // Variants override these per size; plots snapshot whichever applied.
  // Marking a template live requires these (and every variant's) to be
  // filled — enforced in the go-live transition.
  buildBudget Float?
  salePrice   Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jobs         TemplateJob[]
  materials    TemplateMaterial[]
  documents    TemplateDocument[]
  variants     TemplateVariant[]
  auditEvents  TemplateAuditEvent[]
  sourcedPlots Plot[]             @relation("PlotSourceTemplate")
}

// ---------- Template Variants ----------
// Single template can carry multiple variants (e.g. a 2-storey house with
// 765/775/923/990/1047 sq-ft plot variations). Same stage list, same
// sub-jobs, same orders — but per-variant per-job duration overrides AND
// per-variant per-material qty overrides. Apply-template picks one variant
// at apply time.
model TemplateVariant {
  id          String   @id @default(cuid())
  templateId  String
  name        String   // e.g. "765", "Apple Tree"
  description String?
  sortOrder   Int      @default(0)
  // (May 2026 Keith request) Per-variant house value — variants are
  // different sizes (765 vs 1047 sq ft) so each carries its own
  // buildBudget (target cost) + salePrice (GDV). A plot applied from
  // this variant snapshots these onto the Plot row.
  buildBudget Float?
  salePrice   Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  template          PlotTemplate                @relation(fields: [templateId], references: [id], onDelete: Cascade)
  // Full-fat content owned by this variant (May 2026 rework).
  jobs              TemplateJob[]
  materials         TemplateMaterial[]
  documents         TemplateDocument[]
  // Legacy override tables — kept for migration, deprecated post-rework.
  jobOverrides      TemplateVariantJobOverride[]
  materialOverrides TemplateVariantMaterialOverride[]
  appliedToPlots    Plot[]                      @relation("PlotVariant")

  @@unique([templateId, name])
}

model TemplateVariantJobOverride {
  id            String @id @default(cuid())
  variantId     String
  templateJobId String
  durationDays  Int?

  variant     TemplateVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  templateJob TemplateJob     @relation(fields: [templateJobId], references: [id], onDelete: Cascade)

  @@unique([variantId, templateJobId])
}

model TemplateVariantMaterialOverride {
  id                 String @id @default(cuid())
  variantId          String
  templateMaterialId String
  quantity           Float?
  unitCost           Float?

  variant          TemplateVariant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  templateMaterial TemplateMaterial @relation(fields: [templateMaterialId], references: [id], onDelete: Cascade)

  @@unique([variantId, templateMaterialId])
}

// ---------- Template Audit Events ----------
// Lightweight change log so "this used to work, what changed?" has an
// answer. Recorded by the API layer on every mutation — schema lives
// here so the data is durable across deploys.
model TemplateAuditEvent {
  id         String   @id @default(cuid())
  templateId String
  userId     String?
  userName   String?  // captured at write time so user renames don't break history
  action     String   // "created" | "renamed" | "stage_added" | "stage_removed" | "duration_changed" | "order_added" | "order_changed" | "order_removed" | "material_added" | "material_removed" | "variant_added" | "variant_removed" | "marked_live" | "marked_draft" | "cloned_from"
  detail     String?  // human-readable one-liner
  createdAt  DateTime @default(now())

  template PlotTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, createdAt])
}

// ---------- Template Materials (Quants) ----------
// Materials the template expects per plot, tracked manually (not via the order flow).
// Examples: facing bricks, mortar bags, blocks. Copied to PlotMaterial on apply.
model TemplateMaterial {
  id              String   @id @default(cuid())
  templateId      String
  // See TemplateJob.variantId — variants own their full materials list.
  variantId       String?
  name            String
  quantity        Float // per plot
  unit            String   @default("each")
  unitCost        Float? // optional — used for Budget roll-up if present
  category        String? // "Brickwork" | "Groundworks" | etc — for grouping on UI
  notes           String?
  // If set, the material is "consumed" in reporting when jobs with this stageCode complete.
  // With Q1=manual-only, this is informational only for now but we store it for future auto-depletion.
  linkedStageCode String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  template          PlotTemplate                       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  variant           TemplateVariant?                   @relation(fields: [variantId], references: [id], onDelete: Cascade)
  variantOverrides  TemplateVariantMaterialOverride[]
  consumptionEvents TemplateMaterialConsumption[]

  @@index([templateId, variantId])
}

// ---------- Template Material Consumption ----------
// When a job linked to a TemplateMaterial.linkedStageCode starts, we log
// a consumption row so the Quants Burn-Down report can show "expected vs
// actual" by plot. Pure additive log — no UI overrides yet (Keith asked
// for the surface; deeper edit-it-yourself UI is a follow-up).
model TemplateMaterialConsumption {
  id                 String   @id @default(cuid())
  templateMaterialId String
  plotId             String
  jobId              String?  // job that triggered the consumption (nullable so manual logs work)
  quantity           Float
  loggedAt           DateTime @default(now())

  templateMaterial TemplateMaterial @relation(fields: [templateMaterialId], references: [id], onDelete: Cascade)

  @@index([templateMaterialId, loggedAt])
  @@index([plotId])
}

// ---------- Template Documents (Drawings + spec) ----------
model TemplateDocument {
  id         String   @id @default(cuid())
  templateId String
  // See TemplateJob.variantId — variants own their full document list.
  variantId  String?
  name       String
  url        String
  fileName   String
  fileSize   Int?
  mimeType   String?
  category   String? // "DRAWING" | "SPEC" | "OTHER"
  // Placeholder rows are created when a template is cloned — they
  // carry the original metadata (name, fileName) so the user knows
  // what to re-upload, but the storage object is NOT duplicated to
  // keep Supabase costs down. UI shows "Re-upload needed" instead of
  // a download link when `isPlaceholder=true`.
  isPlaceholder Boolean @default(false)
  createdAt  DateTime @default(now())

  template PlotTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  variant  TemplateVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([templateId, variantId])
}

// ---------- Plot Materials (Quants) ----------
// The concrete per-plot quantity. Either copied from TemplateMaterial on apply (sourceType=TEMPLATE)
// or added directly by site admin (sourceType=MANUAL). Admin updates delivered/consumed manually.
model PlotMaterial {
  id              String   @id @default(cuid())
  plotId          String
  sourceType      String // "TEMPLATE" | "MANUAL"
  name            String
  quantity        Float // expected
  unit            String   @default("each")
  unitCost        Float?
  category        String?
  delivered       Float    @default(0)
  consumed        Float    @default(0)
  notes           String?
  linkedStageCode String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  plot Plot @relation(fields: [plotId], references: [id], onDelete: Cascade)

  @@index([plotId]) // (audit S-P1) was missing — every budget /
  //                   plot-detail / handover query filters on plotId
}

model TemplateJob {
  id                  String   @id @default(cuid())
  templateId          String
  // When variantId is set, this job belongs to that variant only.
  // When variantId is null, it belongs to the base template directly
  // (used at apply-time when the user picks no variant). Variants own
  // their full job tree — adding/removing stages on a variant doesn't
  // affect the base or sibling variants. (May 2026 rework — replaces
  // the older overlay model.)
  variantId           String?
  name                String
  description         String?
  stageCode           String?
  sortOrder           Int      @default(0)
  startWeek           Int
  endWeek             Int
  durationWeeks       Int?
  // Optional days-granularity override. When set, takes precedence over
  // durationWeeks at apply-template time. Allows sub-jobs shorter than
  // a week (e.g. a 3-day paint touch-up) without forcing every existing
  // weeks-based template to migrate.
  durationDays        Int?
  weatherAffected     Boolean  @default(false)
  weatherAffectedType String? // "RAIN" | "TEMPERATURE" | "BOTH"
  parentId            String?
  contactId           String?
  createdAt           DateTime @default(now())

  template         PlotTemplate                  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  variant          TemplateVariant?              @relation(fields: [variantId], references: [id], onDelete: Cascade)
  parent           TemplateJob?                  @relation("SubJobs", fields: [parentId], references: [id], onDelete: Cascade)
  children         TemplateJob[]                 @relation("SubJobs")
  contact          Contact?                      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  orders           TemplateOrder[]
  anchoredOrders   TemplateOrder[]               @relation("OrderAnchorJob")
  variantOverrides TemplateVariantJobOverride[]

  @@index([templateId, variantId])
}

model TemplateOrder {
  id                 String   @id @default(cuid())
  templateJobId      String
  supplierId         String?
  itemsDescription   String?
  orderWeekOffset    Int      @default(-2)
  deliveryWeekOffset Int      @default(0)
  anchorType         String?
  anchorAmount       Int?
  anchorUnit         String?
  anchorDirection    String?
  anchorJobId        String?
  leadTimeAmount     Int?
  leadTimeUnit       String?
  createdAt          DateTime @default(now())

  templateJob TemplateJob         @relation(fields: [templateJobId], references: [id], onDelete: Cascade)
  supplier    Supplier?           @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  anchorJob   TemplateJob?        @relation("OrderAnchorJob", fields: [anchorJobId], references: [id], onDelete: SetNull)
  items       TemplateOrderItem[]
}

model TemplateOrderItem {
  id              String @id @default(cuid())
  templateOrderId String
  name            String
  quantity        Float  @default(1)
  unit            String @default("units")
  unitCost        Float  @default(0)

  templateOrder TemplateOrder @relation(fields: [templateOrderId], references: [id], onDelete: Cascade)
}

// ---------- Push Notifications ----------

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// (May 2026 audit #196) Customer-facing push subscription, keyed by
/// plot share-token rather than a User. Created when a buyer clicks
/// "Get progress notifications" on /progress/[token] and grants
/// browser permission. No auth required — the share token is the
/// identity proof. Subscriptions are dropped when the underlying
/// plot is deleted.
model CustomerPushSubscription {
  id          String   @id @default(cuid())
  plotId      String
  endpoint    String   @unique
  p256dh      String
  auth        String
  userAgent   String?
  createdAt   DateTime @default(now())

  plot Plot @relation(fields: [plotId], references: [id], onDelete: Cascade)

  @@index([plotId])
}

model NotificationPreference {
  id      String           @id @default(cuid())
  userId  String
  type    NotificationType
  enabled Boolean          @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

/// (May 2026 audit #152) "I'm watching this site." Distinct from
/// UserSite assignment (which is access control + RBAC) — watching is
/// notification opt-in. A user with site access can choose to watch
/// (get notified about events on this site) without being officially
/// assigned, and the converse: an assignee on a busy site can mute it.
///
/// Future: cron handlers will read this to scope per-user push
/// notifications. Today only the schema + API + UI ship.
model WatchedSite {
  id        String   @id @default(cuid())
  userId    String
  siteId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([userId, siteId])
  @@index([userId])
  @@index([siteId])
}

// ---------- User Permissions ----------

model UserPermission {
  id         String @id @default(cuid())
  userId     String
  permission String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permission])
}

// ---------- User Site Access (many-to-many) ----------

model UserSite {
  id     String @id @default(cuid())
  userId String
  siteId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([userId, siteId])
}

// ---------- Snagging / Defects ----------

model Snag {
  id           String       @id @default(cuid())
  plotId       String
  jobId        String?
  description  String
  location     String?
  priority     SnagPriority @default(MEDIUM)
  status       SnagStatus   @default(OPEN)
  assignedToId String?
  contactId    String?
  raisedById   String
  resolvedAt   DateTime?
  resolvedById String?
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  plot       Plot        @relation(fields: [plotId], references: [id], onDelete: Cascade)
  job        Job?        @relation(fields: [jobId], references: [id], onDelete: SetNull)
  assignedTo User?       @relation("SnagAssigned", fields: [assignedToId], references: [id])
  contact    Contact?    @relation(fields: [contactId], references: [id])
  raisedBy   User        @relation("SnagRaised", fields: [raisedById], references: [id])
  resolvedBy User?       @relation("SnagResolved", fields: [resolvedById], references: [id])
  photos     SnagPhoto[]

  @@index([plotId])      // hot: snag lists per plot
  @@index([status])      // hot: "OPEN / IN_PROGRESS" filter on every snag view
  @@index([contactId])   // hot: contractor comms "Snags Assigned" filter
  @@index([createdAt])   // (audit P-*) stale-snag > N days queries
  @@index([resolvedAt])  // (audit P-*) avg resolution-time queries
}

model SnagPhoto {
  id        String   @id @default(cuid())
  snagId    String
  url       String
  fileName  String?
  tag       String? // "before", "after"
  createdAt DateTime @default(now())

  snag Snag @relation(fields: [snagId], references: [id], onDelete: Cascade)

  @@index([snagId])      // hot: every snag fetches its photos
}

// ---------- Document Storage ----------

model SiteDocument {
  id           String   @id @default(cuid())
  name         String
  url          String
  fileName     String
  fileSize     Int?
  mimeType     String?
  // Category lets us distinguish drawings from handover certs etc.
  // "DRAWING" | "SPEC" | "CERT" | "HANDOVER" | "OTHER" | "RAMS"
  category     String?
  // Exactly one of siteId / contactId should be set. Site-scoped documents
  // (drawings, specs, handover certs) go through siteId. Contractor-scoped
  // documents (RAMS, method statements) go through contactId — they
  // apply across every site the contractor works on.
  siteId       String?
  plotId       String?
  jobId        String?
  contactId    String?
  uploadedById String
  createdAt    DateTime @default(now())

  // (May 2026 audit S-P0) Pre-fix `contactId` Cascade meant deleting
  // a Contact wiped their RAMS / compliance evidence. SetNull
  // preserves the document; the orphan record shows "(contact
  // archived)" in the UI but the file + audit trail survive.
  site            Site?                @relation(fields: [siteId], references: [id], onDelete: SetNull)
  plot            Plot?                @relation(fields: [plotId], references: [id], onDelete: SetNull)
  job             Job?                 @relation(fields: [jobId], references: [id], onDelete: SetNull)
  contact         Contact?             @relation(fields: [contactId], references: [id], onDelete: SetNull)
  uploadedBy      User                 @relation("UploadedDocuments", fields: [uploadedById], references: [id])
  handoverItems   HandoverChecklist[]
  complianceItems SiteComplianceItem[] @relation("ComplianceDocument")

  @@index([contactId])
  @@index([siteId])        // hot: site-docs list
  @@index([plotId])        // hot: plot-docs drawer
  @@index([jobId])         // hot: job-docs tab
}

// ---------- Handover Pack ----------

/// (May 2026 audit #57) Per-site compliance tracker. Each row is one
/// item the site must hold: insurance certificate, CDM appointment,
/// section-61 noise consent, environment-agency permit, etc.
/// `expiresAt` is optional — some compliance items don't expire.
/// Status flips to EXPIRED automatically when expiresAt < now.
model SiteComplianceItem {
  id          String                   @id @default(cuid())
  siteId      String
  name        String
  category    String? // INSURANCE | PERMIT | CDM | ENVIRONMENT | OTHER
  status      SiteComplianceStatus     @default(PENDING)
  documentId  String?
  expiresAt   DateTime?
  notes       String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  site     Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  document SiteDocument? @relation("ComplianceDocument", fields: [documentId], references: [id], onDelete: SetNull)

  @@index([siteId])
  @@index([expiresAt])
}

enum SiteComplianceStatus {
  PENDING
  ACTIVE
  EXPIRED
  EXEMPT
}

/// (May 2026 audit #176) Toolbox talks: short safety briefings logged
/// when delivered. Each row records the topic, when, and who attended
/// (as a comma-separated free text field — full attendance schema would
/// require linking to Contact rows for non-User attendees).
model ToolboxTalk {
  id           String   @id @default(cuid())
  siteId       String
  topic        String
  notes        String?
  attendees    String? // free-text comma list — manually-typed worker names
  // (May 2026 Keith request) Linked contractors — Contact ids of the
  // contractors who attended. Stored as a text array (not a join table)
  // because Contacts are soft-deleted, so an id here stays resolvable;
  // the contractor-comms query filters with `contractorIds has <id>`.
  // The free-text `attendees` field stays for ad-hoc worker names.
  contractorIds String[] @default([])
  deliveredAt  DateTime @default(now())
  deliveredBy  String? // userId of the manager who ran it (nullable so future scripted entries are possible)
  // (#175) Optional attached document — e.g. signed register, briefing
  // slide deck, RAMS reference. Stored in the same Supabase photos
  // bucket as job photos; we keep the original filename + size so the
  // download link reads sensibly.
  documentUrl       String?
  documentFileName  String?
  documentSize      Int?
  documentMimeType  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, deliveredAt])
}

/// (May 2026 audit #178) Non-Conformance Report — heavier than a snag.
/// Raised when work doesn't meet spec, requires investigation, and is
/// QA-process bound. Tracks the cycle: raised → investigation →
/// corrective action → closed. Distinct from snags so the snag flow
/// stays light + frequent.
model NCR {
  id                String       @id @default(cuid())
  siteId            String
  plotId            String?
  jobId             String?
  contactId         String?
  ref               String? // optional short reference shown on PDFs (e.g. NCR-001)
  title             String
  description       String
  rootCause         String?
  correctiveAction  String?
  status            NCRStatus    @default(OPEN)
  raisedById        String?
  closedById        String?
  raisedAt          DateTime     @default(now())
  closedAt          DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  site     Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  plot     Plot?    @relation(fields: [plotId], references: [id], onDelete: SetNull)
  job      Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)
  contact  Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([siteId, status])
  @@index([plotId])
}

enum NCRStatus {
  OPEN
  INVESTIGATING
  AWAITING_CORRECTION
  RESOLVED
  CLOSED
}

/// (May 2026 audit #175) Pre-start checklist items per plot. Free-form
/// — admins add items as the plot progresses. Common entries: ground
/// survey complete, services connected, scaffold inspected, etc.
/// Future: link to job-action so completing a check is a side-effect.
model PreStartCheck {
  id          String    @id @default(cuid())
  plotId      String
  label       String
  checked     Boolean   @default(false)
  checkedAt   DateTime?
  checkedById String?
  sortOrder   Int       @default(0)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  plot Plot @relation(fields: [plotId], references: [id], onDelete: Cascade)

  @@index([plotId, sortOrder])
}

/// (May 2026 audit #169) Variations: customer-requested or designer-
/// requested changes during the build. Each row tracks what changed,
/// who requested it, cost impact, time impact, and approval status.
model Variation {
  id          String          @id @default(cuid())
  plotId      String
  ref         String? // VAR-001 style
  title       String
  description String?
  requestedBy String? // free text — customer, designer, contractor
  costDelta   Float? // £ change (positive = more cost)
  daysDelta   Int? // working-day change
  status      VariationStatus @default(REQUESTED)
  approvedById String?
  approvedAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  plot Plot @relation(fields: [plotId], references: [id], onDelete: Cascade)

  @@index([plotId])
}

enum VariationStatus {
  REQUESTED
  APPROVED
  REJECTED
  IMPLEMENTED
}

/// (May 2026 audit #177) Defect-liability tracker — post-handover
/// defects raised during the warranty period. Distinct from snags
/// (which are pre-handover); defects belong to the customer's
/// warranty claim, not the build phase QA.
model DefectReport {
  id            String              @id @default(cuid())
  plotId        String
  ref           String? // DEF-001 style
  title         String
  description   String
  status        DefectReportStatus  @default(REPORTED)
  reportedAt    DateTime            @default(now())
  resolvedAt    DateTime?
  reportedById  String?
  resolvedById  String?
  contractorId  String? // assigned contractor (Contact.id)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  plot Plot @relation(fields: [plotId], references: [id], onDelete: Cascade)

  @@index([plotId, status])
}

enum DefectReportStatus {
  REPORTED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

/// (May 2026 audit #56) White-label settings. Singleton row keyed on
/// id="default" — exactly one app-wide brand because the installation
/// is the tenant. Logo URL points at Supabase storage same as other
/// docs; primaryColor is a hex string applied via a CSS variable on
/// the dashboard layout.
model AppSettings {
  id           String   @id @default("default")
  brandName    String   @default("Sight Manager")
  logoUrl      String?
  primaryColor String   @default("#2563eb")
  supportEmail String?
  updatedAt    DateTime @updatedAt
}

/// (May 2026 audit #166) Draw schedule — financial milestone payments
/// the customer makes during the build (e.g. 10% deposit, 30% on damp
/// proof course, 50% on roof complete, 10% on handover). Each row is
/// one milestone with amount, due date, status, and an optional
/// linked job that triggers due-status when complete.
model PlotDrawSchedule {
  id            String           @id @default(cuid())
  plotId        String
  name          String
  amount        Float
  sortOrder     Int              @default(0)
  triggerJobId  String? // optional: when this job completes, status flips DUE
  dueAt         DateTime?
  status        PlotDrawStatus   @default(SCHEDULED)
  paidAt        DateTime?
  paidById      String?
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  plot Plot @relation(fields: [plotId], references: [id], onDelete: Cascade)

  @@index([plotId, sortOrder])
}

enum PlotDrawStatus {
  SCHEDULED
  DUE
  PAID
  WAIVED
}

/// (#191) Lateness — one row per (target, kind, day-it-first-went-late).
/// The cron creates rows when something crosses its deadline; managers
/// optionally tag a reason + attribute responsibility; the row stays
/// open until the target resolves (job completes, order delivered, etc.).
///
/// Why a separate table from EventLog? EventLog is an append-only audit
/// of "what happened" — useful for timelines. LatenessEvent is the
/// MUTABLE state record of "what's currently late + why" — useful for
/// reports, dashboards, the Site Story tab. The two complement each
/// other; we cross-emit one EventLog row when a LatenessEvent opens
/// and another when it resolves so the timeline still has the breadcrumb.
model LatenessEvent {
  id                  String         @id @default(cuid())
  kind                LatenessKind

  /// Discriminator. "job" or "order" — denormalised so we never join
  /// two tables to know what kind of thing this row points at.
  targetType          String
  targetId            String

  /// Denormalised scope for fast filtering. siteId is always set;
  /// plotId/jobId/orderId fill in based on kind.
  siteId              String
  plotId              String?
  jobId               String?
  orderId             String?

  /// Day the target first crossed its deadline (working-day-aligned to
  /// midnight). Used by the unique constraint so the daily cron never
  /// double-opens.
  wentLateOn          DateTime

  /// Working-day count of how far late the target currently is.
  /// Refreshed by the daily cron until the row resolves.
  daysLate            Int            @default(1)

  /// Set when the target resolves (job completes, order delivered,
  /// etc.). Null = still open.
  resolvedAt          DateTime?

  /// Reason + attribution. reasonCode defaults to OTHER until a manager
  /// (or an inference rule) sets it.
  reasonCode          LatenessReason @default(OTHER)
  reasonNote          String?

  /// (May 2026) Specific, manager-picked reason from the self-growing
  /// DelayReason table — used by order-send + order-delivery lateness
  /// where the broad `reasonCode` enum isn't granular enough and the
  /// reason list needs to grow over time. `reasonCode` stays the broad
  /// reporting bucket; `delayReason` is the specific cause.
  delayReasonId       String?

  /// (May 2026) Manager marked this lateness as "no programme impact"
  /// — e.g. an order sent late but the material wasn't needed early.
  /// Still recorded for the audit trail, but excluded from the Delay
  /// Report's headline delay counts (surfaced in a separate excused
  /// bucket — the same treatment weather-excused lateness gets).
  excused             Boolean        @default(false)

  /// Which contractor or supplier carried the slip, if attributable.
  /// (May 2026 audit S-P1 / FC-P0) Pre-fix only `attributedContactId`
  /// existed — pointed at the Contact table. Material suppliers live
  /// in a separate Supplier table, so order-driven lateness (the
  /// cron auto-attributes via order.contactId, but most orders don't
  /// have a Contact assigned) never gained supplier attribution.
  /// Added `attributedSupplierId` as a parallel field. UI + analytics
  /// queries the union. A future schema refactor will unify Supplier
  /// into Contact and collapse these two fields back into one.
  attributedContactId  String?
  attributedSupplierId String?
  recordedById         String?        // user who set the reason

  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  site               Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  plot               Plot?          @relation(fields: [plotId], references: [id], onDelete: SetNull)
  job                Job?           @relation(fields: [jobId], references: [id], onDelete: SetNull)
  order              MaterialOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  attributedContact  Contact?       @relation(fields: [attributedContactId], references: [id], onDelete: SetNull)
  attributedSupplier Supplier?      @relation(fields: [attributedSupplierId], references: [id], onDelete: SetNull)
  recordedBy         User?          @relation("LatenessEventRecorder", fields: [recordedById], references: [id], onDelete: SetNull)
  delayReason        DelayReason?   @relation(fields: [delayReasonId], references: [id], onDelete: SetNull)

  /// One open event per (target, kind, day-it-went-late). The cron's
  /// upsert relies on this so it never creates duplicates.
  @@unique([targetType, targetId, kind, wentLateOn])
  @@index([siteId, wentLateOn])
  @@index([resolvedAt])
  @@index([attributedContactId])
  @@index([attributedSupplierId])
  @@index([reasonCode])
  @@index([delayReasonId])
  @@index([plotId])
  @@index([jobId])
  @@index([orderId])
}

/// (May 2026 audit #49) Voice notes recorded on a job/plot/snag.
/// The file lives in Supabase storage (same bucket as photos);
/// transcription is the future tier — initial version is just the
/// audio + optional caption.
model VoiceNote {
  id          String   @id @default(cuid())
  plotId      String
  jobId       String?
  snagId      String?
  url         String
  durationSec Int?
  caption     String?
  transcript  String? // future: ASR fills this
  createdAt   DateTime @default(now())
  createdById String?

  plot Plot @relation(fields: [plotId], references: [id], onDelete: Cascade)

  @@index([plotId, createdAt])
}

/// (May 2026 audit #50) Annotations layered on top of a job photo —
/// arrows, circles, freehand strokes. Serialised as a JSON `strokes`
/// blob so the front-end can re-render the canvas. Distinct from
/// JobPhoto so the original photo stays untouched + multiple users
/// can annotate the same photo without conflicts.
model PhotoAnnotation {
  id          String   @id @default(cuid())
  jobPhotoId  String
  plotId      String
  strokes     String // JSON-encoded array of stroke objects
  caption     String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  plot     Plot     @relation(fields: [plotId], references: [id], onDelete: Cascade)
  jobPhoto JobPhoto @relation(fields: [jobPhotoId], references: [id], onDelete: Cascade)

  @@index([jobPhotoId])
  @@index([plotId])
}

model HandoverChecklist {
  id          String    @id @default(cuid())
  plotId      String
  docType     String // EPC, GAS_SAFE_CERT, ELECTRICAL_CERT, WARRANTY, NHBC_CERT, BUILDING_REGS, USER_MANUAL, FLOOR_PLAN, SNAGGING_SIGNOFF
  required    Boolean   @default(true)
  documentId  String?
  checkedAt   DateTime?
  checkedById String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  plot      Plot          @relation(fields: [plotId], references: [id], onDelete: Cascade)
  document  SiteDocument? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  checkedBy User?         @relation("CheckedHandoverItems", fields: [checkedById], references: [id])

  @@unique([plotId, docType])
}

// ---------- Delay Reasons ----------

// Curated + learned list of delay reasons. Seeded with common ones
// (Contractor no-show, Order delay, Material missing, Rain, Temperature
// etc.); when a user types a NEW reason in the delay dialog, it gets
// upserted here so next time it appears as a quick-pick chip. Sorted
// by usageCount so the most-used reasons float to the top.
//
// `category` buckets the reason for the Delay Report — must be one
// of: WEATHER_RAIN | WEATHER_TEMPERATURE | OTHER. Used to fill
// EventLog.delayReasonType when a delay is recorded.
model DelayReason {
  id          String    @id @default(cuid())
  label       String    @unique
  category    String    @default("OTHER")
  usageCount  Int       @default(0)
  isSystem    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?

  // (May 2026) Which picker shows this reason. null = the original
  // general/job-delay list (existing behaviour). "ORDER_SEND" =
  // why-an-order-went-out-late picker; "ORDER_DELIVERY" = why-a-
  // delivery-was-late picker. Keeps the three contexts from polluting
  // each other while still sharing one self-growing table — a custom
  // "Other" reason typed in any picker is upserted here and reappears
  // next time, scoped to where it was added.
  scope       String?

  latenessEvents LatenessEvent[]

  @@index([usageCount])
  @@index([scope])
}

// ---------- Event Log ----------

/// IMMUTABLE — audit log. APPEND-ONLY by contract.
///
/// EventLog rows are the source of truth for "what happened on this site"
/// (story tab, delay analytics, regulator pack inside the handover ZIP).
/// Mutating a past event would corrupt all of those.
///
/// Rules:
///   1. Code only ever calls `prisma.eventLog.create()`. No update / delete
///      routes exist anywhere in the API surface — verified by
///      `grep "eventLog\.(update|delete|deleteMany|updateMany)"` returning
///      empty. Anyone adding such a call MUST justify it in code review.
///   2. Cascade deletes via FK are allowed when the parent (Site / Plot /
///      Job / User) is removed — `onDelete` is set deliberately. Site uses
///      Cascade so a deleted site doesn't leave dangling logs; plot/job/
///      user use SetNull so site-level history survives those deletions.
///      This is the only sanctioned removal path.
///   3. (May 2026 audit #74) An explicit DB-level CHECK / trigger isn't
///      added because Prisma is the only thing that talks to this table.
///      The contract is enforced at the application layer.
model EventLog {
  id              String    @id @default(cuid())
  type            EventType
  description     String
  siteId          String?
  plotId          String?
  jobId           String?
  userId          String?
  delayReasonType String? // WEATHER_RAIN | WEATHER_TEMPERATURE | OTHER — set when type=SCHEDULE_CASCADED
  createdAt       DateTime  @default(now())

  // (May 2026 Keith bug report) Site FK is SetNull, not Cascade. Pre-
  // fix Site delete tried to cascade-delete EventLog rows, which was
  // blocked by the eventlog_no_delete immutability trigger from batch
  // 143, so site delete always failed. Schema-audit also explicitly
  // wanted SetNull here — closed-site EventLogs are the audit trail
  // a regulator wants to read. Trigger updated to allow this specific
  // SetNull update (see scripts/apply-eventlog-cascade-fix.ts).
  site Site? @relation(fields: [siteId], references: [id], onDelete: SetNull)
  plot Plot? @relation(fields: [plotId], references: [id], onDelete: SetNull)
  job  Job?  @relation(fields: [jobId], references: [id], onDelete: SetNull)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([siteId, createdAt])  // hot: events-log paginated by site
  @@index([jobId])              // hot: job history panel
  @@index([plotId])              // hot: plot activity timeline
  @@index([type])                // hot: filter by event type in events-log
}
