generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum UserRole {
  CEO
  DIRECTOR
  SITE_MANAGER
  CONTRACT_MANAGER
  CONTRACTOR
}

enum SiteStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum JobStatus {
  NOT_STARTED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
}

enum OrderStatus {
  PENDING
  ORDERED
  CONFIRMED
  DELIVERED
  CANCELLED
}

enum ContactType {
  SUPPLIER
  CONTRACTOR
}

enum NotificationType {
  JOBS_STARTING_TODAY
  JOBS_OVERDUE
  MATERIALS_OVERDUE
  DELIVERIES_DUE_TODAY
  JOBS_READY_FOR_SIGNOFF
  NEW_NOTES_PHOTOS
  ORDERS_TO_SEND
  NEXT_STAGE_READY
  LATE_STARTS
}

enum SnagPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SnagStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum EventType {
  JOB_STARTED
  JOB_COMPLETED
  JOB_STOPPED
  JOB_EDITED
  JOB_SIGNED_OFF
  ORDER_PLACED
  ORDER_DELIVERED
  ORDER_CANCELLED
  DELIVERY_CONFIRMED
  PHOTO_UPLOADED
  SCHEDULE_CASCADED
  SITE_CREATED
  SITE_UPDATED
  PLOT_CREATED
  PLOT_UPDATED
  SNAG_CREATED
  SNAG_RESOLVED
  USER_ACTION
  NOTIFICATION
  SYSTEM
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          UserRole  @default(CONTRACTOR)
  jobTitle      String?
  company       String?
  phone         String?
  avatar        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sites         Site[]
  assignedJobs  Job[]        @relation("AssignedJobs")
  signedOffJobs Job[]        @relation("SignedOffJobs")
  events        EventLog[]
  jobActions    JobAction[]
  uploadedPhotos JobPhoto[]
  pushSubscriptions       PushSubscription[]
  notificationPreferences NotificationPreference[]
  permissions             UserPermission[]
  snagsAssigned    Snag[]         @relation("SnagAssigned")
  snagsRaised      Snag[]         @relation("SnagRaised")
  snagsResolved    Snag[]         @relation("SnagResolved")
  uploadedDocuments  SiteDocument[]      @relation("UploadedDocuments")
  checkedHandovers   HandoverChecklist[] @relation("CheckedHandoverItems")
}

model Site {
  id          String     @id @default(cuid())
  name        String
  description String?
  location    String?
  address     String?
  postcode    String?
  status      SiteStatus @default(ACTIVE)
  createdById String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  createdBy     User           @relation(fields: [createdById], references: [id])
  plots         Plot[]
  events        EventLog[]
  rainedOffDays RainedOffDay[]
  documents     SiteDocument[]
}

model RainedOffDay {
  id        String   @id @default(cuid())
  siteId    String
  date      DateTime
  note      String?
  createdAt DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, date])
}

model Plot {
  id                   String    @id @default(cuid())
  name                 String
  description          String?
  siteId               String
  plotNumber           String?
  reservationType      String?
  houseType            String?
  reservationDate      DateTime?
  exchangeDate         DateTime?
  legalDate            DateTime?
  approvalG            Boolean   @default(false)
  approvalE            Boolean   @default(false)
  approvalW            Boolean   @default(false)
  approvalKCO          Boolean   @default(false)
  buildCompletePercent Float     @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  site              Site               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  jobs              Job[]
  events            EventLog[]
  snags             Snag[]
  documents         SiteDocument[]
  handoverChecklist HandoverChecklist[]

  @@unique([siteId, plotNumber])
}

model Job {
  id              String    @id @default(cuid())
  name            String
  description     String?
  plotId          String
  location        String?
  address         String?
  startDate       DateTime?
  endDate         DateTime?
  status          JobStatus @default(NOT_STARTED)
  assignedToId    String?
  stageCode       String?
  actualStartDate DateTime?
  actualEndDate   DateTime?
  signedOffById   String?
  signedOffAt     DateTime?
  signOffNotes    String?
  sortOrder       Int       @default(0)
  weatherAffected Boolean   @default(false)
  parentId        String?
  parentStage     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  plot          Plot            @relation(fields: [plotId], references: [id], onDelete: Cascade)
  assignedTo    User?           @relation("AssignedJobs", fields: [assignedToId], references: [id])
  signedOffBy   User?           @relation("SignedOffJobs", fields: [signedOffById], references: [id])
  parent        Job?            @relation("SubJobs", fields: [parentId], references: [id], onDelete: SetNull)
  children      Job[]           @relation("SubJobs")
  orders        MaterialOrder[]
  events        EventLog[]
  actions       JobAction[]
  contractors   JobContractor[]
  photos        JobPhoto[]
  documents     SiteDocument[]
  snags         Snag[]
}

model JobAction {
  id          String    @id @default(cuid())
  jobId       String
  userId      String
  action      String
  notes       String?
  createdAt   DateTime  @default(now())

  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id])
}

model JobContractor {
  id        String   @id @default(cuid())
  jobId     String
  contactId String
  createdAt DateTime @default(now())

  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([jobId, contactId])
}

model JobPhoto {
  id           String   @id @default(cuid())
  jobId        String
  url          String
  fileName     String?
  caption      String?
  tag          String?  // "before", "after", "progress"
  uploadedById String?
  createdAt    DateTime @default(now())

  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
}

model Supplier {
  id              String    @id @default(cuid())
  name            String
  contactName     String?
  contactEmail    String?
  contactNumber   String?
  type            String?
  emailTemplate   String?
  accountNumber   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  orders          MaterialOrder[]
  templateOrders  TemplateOrder[]
  materials       SupplierMaterial[]
}

model SupplierMaterial {
  id         String   @id @default(cuid())
  supplierId String
  name       String
  unit       String   @default("each")
  unitCost   Float    @default(0)
  category   String?
  sku        String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([supplierId, name])
}

model MaterialOrder {
  id                    String      @id @default(cuid())
  supplierId            String
  jobId                 String
  contactId             String?
  orderDetails          String?
  dateOfOrder           DateTime    @default(now())
  orderType             String?
  automated             Boolean     @default(false)
  status                OrderStatus @default(PENDING)
  expectedDeliveryDate  DateTime?
  deliveredDate         DateTime?
  leadTimeDays          Int?
  itemsDescription      String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  supplier              Supplier    @relation(fields: [supplierId], references: [id])
  job                   Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  contact               Contact?    @relation(fields: [contactId], references: [id], onDelete: SetNull)
  orderItems            OrderItem[]
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  name      String
  quantity  Float    @default(1)
  unit      String   @default("units")
  unitCost  Float    @default(0)
  totalCost Float    @default(0)
  createdAt DateTime @default(now())

  order     MaterialOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Contact {
  id        String      @id @default(cuid())
  name      String
  email     String?
  phone     String?
  type      ContactType
  company   String?
  notes     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  orders          MaterialOrder[]
  jobContractors  JobContractor[]
  templateJobs    TemplateJob[]
  snags           Snag[]
}

// ---------- Plot Templates ----------

model PlotTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  typeLabel   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jobs        TemplateJob[]
}

model TemplateJob {
  id            String   @id @default(cuid())
  templateId    String
  name          String
  description   String?
  stageCode     String?
  sortOrder     Int      @default(0)
  startWeek     Int
  endWeek       Int
  durationWeeks   Int?
  weatherAffected Boolean  @default(false)
  parentId        String?
  contactId       String?
  createdAt       DateTime @default(now())

  template    PlotTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  parent      TemplateJob?  @relation("SubJobs", fields: [parentId], references: [id], onDelete: Cascade)
  children    TemplateJob[] @relation("SubJobs")
  contact     Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  orders         TemplateOrder[]
  anchoredOrders TemplateOrder[] @relation("OrderAnchorJob")
}

model TemplateOrder {
  id                   String   @id @default(cuid())
  templateJobId        String
  supplierId           String?
  itemsDescription     String?
  orderWeekOffset      Int      @default(-2)
  deliveryWeekOffset   Int      @default(0)
  anchorType           String?
  anchorAmount         Int?
  anchorUnit           String?
  anchorDirection      String?
  anchorJobId          String?
  leadTimeAmount       Int?
  leadTimeUnit         String?
  createdAt            DateTime @default(now())

  templateJob          TemplateJob  @relation(fields: [templateJobId], references: [id], onDelete: Cascade)
  supplier             Supplier?    @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  anchorJob            TemplateJob? @relation("OrderAnchorJob", fields: [anchorJobId], references: [id], onDelete: SetNull)
  items                TemplateOrderItem[]
}

model TemplateOrderItem {
  id              String  @id @default(cuid())
  templateOrderId String
  name            String
  quantity        Float   @default(1)
  unit            String  @default("units")
  unitCost        Float   @default(0)

  templateOrder   TemplateOrder @relation(fields: [templateOrderId], references: [id], onDelete: Cascade)
}

// ---------- Push Notifications ----------

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationPreference {
  id      String           @id @default(cuid())
  userId  String
  type    NotificationType
  enabled Boolean          @default(true)

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

// ---------- User Permissions ----------

model UserPermission {
  id         String @id @default(cuid())
  userId     String
  permission String

  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permission])
}

// ---------- Snagging / Defects ----------

model Snag {
  id            String       @id @default(cuid())
  plotId        String
  jobId         String?
  description   String
  location      String?
  priority      SnagPriority @default(MEDIUM)
  status        SnagStatus   @default(OPEN)
  assignedToId  String?
  contactId     String?
  raisedById    String
  resolvedAt    DateTime?
  resolvedById  String?
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  plot          Plot         @relation(fields: [plotId], references: [id], onDelete: Cascade)
  job           Job?         @relation(fields: [jobId], references: [id], onDelete: SetNull)
  assignedTo    User?        @relation("SnagAssigned", fields: [assignedToId], references: [id])
  contact       Contact?     @relation(fields: [contactId], references: [id])
  raisedBy      User         @relation("SnagRaised", fields: [raisedById], references: [id])
  resolvedBy    User?        @relation("SnagResolved", fields: [resolvedById], references: [id])
  photos        SnagPhoto[]
}

model SnagPhoto {
  id        String   @id @default(cuid())
  snagId    String
  url       String
  fileName  String?
  tag       String?  // "before", "after"
  createdAt DateTime @default(now())

  snag      Snag     @relation(fields: [snagId], references: [id], onDelete: Cascade)
}

// ---------- Document Storage ----------

model SiteDocument {
  id           String   @id @default(cuid())
  name         String
  url          String
  fileName     String
  fileSize     Int?
  mimeType     String?
  siteId       String
  plotId       String?
  jobId        String?
  uploadedById String
  createdAt    DateTime @default(now())

  site           Site               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  plot           Plot?              @relation(fields: [plotId], references: [id], onDelete: SetNull)
  job            Job?               @relation(fields: [jobId], references: [id], onDelete: SetNull)
  uploadedBy     User               @relation("UploadedDocuments", fields: [uploadedById], references: [id])
  handoverItems  HandoverChecklist[]
}

// ---------- Handover Pack ----------

model HandoverChecklist {
  id          String    @id @default(cuid())
  plotId      String
  docType     String    // EPC, GAS_SAFE_CERT, ELECTRICAL_CERT, WARRANTY, NHBC_CERT, BUILDING_REGS, USER_MANUAL, FLOOR_PLAN, SNAGGING_SIGNOFF
  required    Boolean   @default(true)
  documentId  String?
  checkedAt   DateTime?
  checkedById String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  plot        Plot           @relation(fields: [plotId], references: [id], onDelete: Cascade)
  document    SiteDocument?  @relation(fields: [documentId], references: [id], onDelete: SetNull)
  checkedBy   User?          @relation("CheckedHandoverItems", fields: [checkedById], references: [id])

  @@unique([plotId, docType])
}

// ---------- Event Log ----------

model EventLog {
  id          String    @id @default(cuid())
  type        EventType
  description String
  siteId      String?
  plotId      String?
  jobId       String?
  userId      String?
  createdAt   DateTime  @default(now())

  site        Site?     @relation(fields: [siteId], references: [id], onDelete: SetNull)
  plot        Plot?     @relation(fields: [plotId], references: [id], onDelete: SetNull)
  job         Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
}
