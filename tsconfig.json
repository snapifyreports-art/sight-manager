{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "simulate-build.ts",
    "seed-riverside.ts",
    "seed-orders.ts",
    "scripts/test-audit-fixes.ts",
    "scripts/test-permissions.ts",
    "scripts/tighten-original-dates.ts",
    "scripts/e2e-full-test.ts",
    "prisma/seed.ts",
    "prisma/seed-latest-site.ts"
  ]
}
